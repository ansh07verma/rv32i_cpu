// ============================================================
// Program 1: prog_arith.mem — Simple Arithmetic Sequence
// Project  : RV32I Single-Cycle Processor — Phase 4
// Format   : $readmemh  (one 32-bit word per line, MSB first)
//
// Register usage:
//   x1 = 20   (ADDI x1, x0, 20)
//   x2 = 7    (ADDI x2, x0, 7)
//   x3 = x1+x2 = 27  (ADD)
//   x4 = x1-x2 = 13  (SUB)
//   x5 = x1 & x2 = 4 (AND)   20=10100, 7=00111 → 00100 = 4
//   x6 = x1 | x2 = 23 (OR)   20=10100, 7=00111 → 10111 = 23
//   x7 = x1 ^ x2 = 19 (XOR)  20=10100, 7=00111 → 10011 = 19
//   x8 = ADDI x8, x0, 1   (x8=1)
//   x9 = SLL x3, x8 = 27<<1 = 54  (SLL by 1)
//   x10= SLT x2, x1 → x10=1 (7 < 20 is TRUE)
//
// PC    Hex          Assembly                    Notes
// 0x00  01400093     ADDI x1, x0, 20             x1 = 20
// 0x04  00700113     ADDI x2, x0, 7              x2 = 7
// 0x08  002081B3     ADD  x3, x1, x2             x3 = 27
// 0x0C  40208233     SUB  x4, x1, x2             x4 = 13
// 0x10  0020F2B3     AND  x5, x1, x2             x5 = 4
// 0x14  0020E333     OR   x6, x1, x2             x6 = 23
// 0x18  0020C3B3     XOR  x7, x1, x2             x7 = 19
// 0x1C  00100413     ADDI x8, x0, 1              x8 = 1
// 0x20  008194B3     SLL  x9, x3, x8             x9 = 54 (27<<1)
// 0x24  0020A533     SLT  x10, x1, x2            x10= 0 (20 < 7 is FALSE)
// 0x28  00112533     SLT  x10, x2, x1            x10= 1 (7 < 20 is TRUE)
// 0x2C  00000013     NOP
// 0x30  00000013     NOP
//
// Encoding verification (selected):
//   ADDI x1,x0,20:  imm=20(0x014), rs1=0, funct3=000, rd=1, op=0010011
//     = 0000_0001_0100_00000_000_00001_0010011 = 0x01400093 ✓
//   ADD x3,x1,x2:   funct7=0, rs2=2, rs1=1, funct3=000, rd=3, op=0110011
//     = 0000000_00010_00001_000_00011_0110011 = 0x002081B3 ✓
//   SUB x4,x1,x2:   funct7=0100000, rs2=2, rs1=1, funct3=000, rd=4, op=0110011
//     = 0100000_00010_00001_000_00100_0110011 = 0x40208233 ✓
//   SLL x9,x3,x8:   funct7=0, rs2=8, rs1=3, funct3=001, rd=9, op=0110011
//     = 0000000_01000_00011_001_01001_0110011 = 0x008194B3 ✓
// ============================================================
01400093
00700113
002081B3
40208233
0020F2B3
0020E333
0020C3B3
00100413
008194B3
0020A533
00112533
00000013
00000013
